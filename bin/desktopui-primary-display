#!/usr/bin/env bash
# Hyprland: bind middle mouse (wheel press) with:
#   bind = , mouse:274, exec, /absolute/path/to/desktopUI/bin/desktopui-primary-display
# Use `wev` if 274 is not your middle button.
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PY="${ROOT}/.venv/bin/python"
if [[ -x "$PY" ]]; then
  exec "$PY" "${ROOT}/services/primary_mouse_display_service.py"
fi
exec python3 "${ROOT}/services/primary_mouse_display_service.py"
